<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext HTTP to the dev server (10.10.0.200) when running a debug
    build.  Production builds only ever talk to https://leafletter.app so no
    cleartext is needed there.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.10.0.200</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
